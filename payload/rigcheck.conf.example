# RigCheck configuration (rename to rigcheck.conf, lives next to rigcheck.sh on the USB)
# All values optional unless noted. Shell syntax: KEY='value'

# Test mode: ask | coffee (~15 min) | standard (~40 min) | detailed (hours)
# 'ask' shows a menu; anything else auto-starts after a 10s countdown (headless-friendly).
MODE='ask'

# --- WiFi (phone hotspot) — used best-effort; ethernet is tried first automatically
WIFI_SSID=''
WIFI_PASSWORD=''
WIFI_COUNTRY=''          # 2-letter code, e.g. IN / US — helps old cards find the hotspot

# --- Email report (needs internet). Gmail: use a 16-char App Password, not your real password.
EMAIL_TO=''
EMAIL_FROM=''
SMTP_HOST=''             # e.g. smtp.gmail.com
SMTP_PORT='587'          # 587 = STARTTLS, 465 = SSL
SMTP_USER=''
SMTP_PASSWORD=''

# --- Optional LLM analysis of the report (needs internet + key)
LLM_PROVIDER='anthropic'
LLM_MODEL='claude-sonnet-4-6'
LLM_API_KEY=''

# --- Safety thresholds (conservative defaults; watchdog aborts stress tests above these)
ABORT_TEMP_C='95'        # CPU package
NVME_ABORT_TEMP_C='82'   # NVMe composite
DISK_ABORT_TEMP_C='70'   # SATA drives (via drivetemp)
# Watchdog also aborts when NEW SMART errors appear mid-run (drive degrading under load).

# --- PC-speaker beeps for headless runs (2=start, 2/3/5=done pass/warn/fail; best-effort)
BEEP='yes'

# --- After an unattended (preselected-mode) run: stay | poweroff
AFTER_TEST='stay'

# --- Report authenticity
CHALLENGE_NONCE=''       # code you texted to whoever runs the test (embedded + signed)
NONCE_PROMPT='no'        # yes = interactively ask for a nonce at start
SIGNING_KEY=''           # hex key generated by make-usb.sh (owner keeps a copy)
SIGNING_KEY_ID=''
